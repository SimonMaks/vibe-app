import tkinter as tk
from tkinter import messagebox  # Для всплывающих окон при победе
from Factory import Button_factory

class Window:
    def __init__(self):
        self.main_window = tk.Tk()
        self.main_window.title("Крестики-Нолики")
        self.main_window.geometry("300x300")

        # Передаем метод check_win в фабрику
        button_factory = Button_factory(self.main_window, self.check_win)
        
        # Двумерный массив для хранения кнопок (чтобы проверять победу)
        self.buttons = [[None for _ in range(3)] for _ in range(3)]

        # Настраиваем растягивание сетки
        for i in range(3):
            self.main_window.rowconfigure(i, weight=1)
            self.main_window.columnconfigure(i, weight=1)

        # Создаем кнопки и размещаем их
        for i in range(3):
            for j in range(3):
                button = button_factory.create_button()
                button.grid(row=i, column=j, sticky="NSEW")
                self.buttons[i][j] = button

    def check_win(self):
        b = self.buttons
        
        # Проверка строк
        for i in range(3):
            if b[i][0]['text'] == b[i][1]['text'] == b[i][2]['text'] != "":
                self.end_game(b[i][0]['text'])
                return
                
        # Проверка столбцов
        for j in range(3):
            if b[0][j]['text'] == b[1][j]['text'] == b[2][j]['text'] != "":
                self.end_game(b[0][j]['text'])
                return
                
        # Проверка диагоналей
        if b[0][0]['text'] == b[1][1]['text'] == b[2][2]['text'] != "":
            self.end_game(b[0][0]['text'])
            return
        if b[0][2]['text'] == b[1][1]['text'] == b[2][0]['text'] != "":
            self.end_game(b[0][2]['text'])
            return

        # Проверка на ничью (если не осталось пустых кнопок)
        if all(b[i][j]['text'] != "" for i in range(3) for j in range(3)):
            self.end_game("Ничья")

    def end_game(self, winner):
        if winner == "Ничья":
            messagebox.showinfo("Конец игры", "У вас ничья!")
        else:
            messagebox.showinfo("Конец игры", f"Победил игрок {winner}!")
        self.main_window.quit() # Закрывает программу после окончания

    def start(self):
        self.main_window.mainloop()

if __name__ == "__main__":
    win = Window()
    win.start()




import tkinter as tk

class Button_factory:
    click_turn = True

    def __init__(self, parent, check_win_callback=None):
        self.parent = parent
        # Коллбэк для проверки победы после каждого хода
        self.check_win_callback = check_win_callback 

    def create_button(self):
        # Создаем новую кнопку при каждом вызове
        button = tk.Button(self.parent, text="", font=('Arial', 24))
        
        # Передаем саму кнопку в функцию обработки нажатия
        button.config(command=lambda b=button: self.button_action(b))
        return button

    def button_action(self, button):
        if Button_factory.click_turn:
            # disabledforeground нужен, чтобы текст оставался черным/четким при блокировке
            button.config(text="X", state="disabled", disabledforeground="black")
            Button_factory.click_turn = False
        else:
            button.config(text="O", state="disabled", disabledforeground="red")
            Button_factory.click_turn = True
            
        # После каждого клика проверяем, нет ли победителя
        if self.check_win_callback:
            self.check_win_callback()
