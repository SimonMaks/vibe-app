{
  "name": "messenger-vibe",
  "private": true,
  "version": "1.1.0",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "make-exe": "vite build && electron-builder --win",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\""
  },
  "build": {
    "appId": "com.SimonMaks.vibemessenger",
    "productName": "Vibe Messenger",
    "publish": [
      {
        "provider": "github",
        "owner": "SimonMaks",
        "repo": "messenger"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "firebase": "^12.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "electron-builder": "^26.8.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "electron": "^31.0.0",
    "vite": "^5.4.1",
    "wait-on": "^9.0.5"
  }
}
